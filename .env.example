# Required: OpenAI API key
OPENAI_API_KEY=

# Optional: Custom LLM endpoint (defaults to OpenAI)
# OPENAI_BASE_URL=https://api.openai.com/v1

# Optional: Model to use (default: gpt-5.2)
# API_AGENT_MODEL_NAME=gpt-5.2

# Optional: Server port (default: 3000)
# API_AGENT_PORT=3000

# Optional: OpenTelemetry tracing endpoint
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# --- Knowledge Synthesis Engine ---

# Neo4j password (default: knowledge123)
# NEO4J_PASSWORD=knowledge123

# RustFS (S3-compatible) credentials
# RUSTFS_ROOT_USER=rustfsadmin
# RUSTFS_ROOT_PASSWORD=rustfsadmin

# Knowledge synthesis LLM model (default: gpt-4o)
# KNOWLEDGE_MODEL=gpt-4o

# Embedding model (default: text-embedding-3-small)
# EMBEDDING_MODEL=text-embedding-3-small

# Optional: Cohere API key for cross-encoder reranking
# COHERE_API_KEY=
